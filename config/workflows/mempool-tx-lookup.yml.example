# Lookup Bitcoin transaction on mempool.space and reply with details
#
# This workflow:
# 1. Receives a DM with "mempool: <txid>"
# 2. Calls mempool.space API to get transaction details
# 3. Replies to sender with formatted transaction info
#
# No configuration required - uses public mempool.space API

id: mempool-tx-lookup
name: Mempool Transaction Lookup
enabled: true

trigger:
  type: nostr_event
  filters:
    kinds: [4]              # NIP-04 DMs
    from_whitelist: true    # Only from whitelisted npubs
    content_pattern: "^[Mm]empool:\\s*(?<txid>[a-fA-F0-9]{64})$"

actions:
  # Step 1: Call mempool.space API
  - id: lookup_tx
    type: http
    config:
      url: "https://mempool.space/api/tx/{{ match.txid }}"
      method: GET
      timeout_ms: 15000

  # Step 2a: Reply for CONFIRMED transactions
  - id: reply_confirmed
    type: nostr_dm
    when: "actions.lookup_tx.success == true && actions.lookup_tx.response.body.status.confirmed == true"
    config:
      to: "{{ trigger.from }}"
      content: |
        TX {{ match.txid | truncate:12 }}

        From: {{ actions.lookup_tx.response.body.vin[0].prevout.scriptpubkey_address | truncate:12 }} ({{ actions.lookup_tx.response.body.vin | length }} inputs)
        To: {{ actions.lookup_tx.response.body.vout[0].scriptpubkey_address | truncate:12 }} ({{ actions.lookup_tx.response.body.vout | length }} outputs)
        Amount: {{ actions.lookup_tx.response.body.vout[0].value | sats_to_btc }} BTC

        Fee: {{ actions.lookup_tx.response.body.fee | number }} sats
        Size: {{ actions.lookup_tx.response.body.size }} vB

        Status: Confirmed
        Block: {{ actions.lookup_tx.response.body.status.block_height | number }}
        Date: {{ actions.lookup_tx.response.body.status.block_time | date_short }}

        https://mempool.space/tx/{{ match.txid }}

  # Step 2b: Reply for PENDING transactions
  - id: reply_pending
    type: nostr_dm
    when: "actions.lookup_tx.success == true && actions.lookup_tx.response.body.status.confirmed == false"
    config:
      to: "{{ trigger.from }}"
      content: |
        TX {{ match.txid | truncate:12 }}

        From: {{ actions.lookup_tx.response.body.vin[0].prevout.scriptpubkey_address | truncate:12 }} ({{ actions.lookup_tx.response.body.vin | length }} inputs)
        To: {{ actions.lookup_tx.response.body.vout[0].scriptpubkey_address | truncate:12 }} ({{ actions.lookup_tx.response.body.vout | length }} outputs)
        Amount: {{ actions.lookup_tx.response.body.vout[0].value | sats_to_btc }} BTC

        Fee: {{ actions.lookup_tx.response.body.fee | number }} sats
        Size: {{ actions.lookup_tx.response.body.size }} vB

        Status: Pending (unconfirmed)

        https://mempool.space/tx/{{ match.txid }}

  # Step 3: Reply with error (failure case)
  - id: reply_error
    type: nostr_dm
    when: "actions.lookup_tx.success == false"
    config:
      to: "{{ trigger.from }}"
      content: |
        Transaction not found or API error

        TXID: {{ match.txid | truncate:16 }}
        Error: {{ actions.lookup_tx.error }}
