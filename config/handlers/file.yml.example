# Configuration File Handler
file:
  enabled: true

  # Répertoire de sortie pour les fichiers générés
  output_dir: "./data/files"

  # Taille maximale d'un fichier (Mo)
  max_file_size_mb: 10

  # Formats autorisés
  allowed_formats:
    - text
    - json
    - csv
    - binary

# Exemples d'utilisation dans un workflow:
