# Configuration Slack Handler
slack:
  enabled: true

  # Mode Webhook (simple, recommandé pour notifications)
  # Créez un webhook: https://api.slack.com/messaging/webhooks
  webhook_url: ${SLACK_WEBHOOK_URL}

  # Mode Bot API (pour fonctionnalités avancées)
  # Créez une app: https://api.slack.com/apps
  # Scopes requis: chat:write
  # bot_token: ${SLACK_BOT_TOKEN}

  # Channel par défaut pour le mode Bot API
  # default_channel: "#general"
