# =============================================================================
# DEPRECATED: WhatsApp handler is temporarily disabled due to security
# vulnerabilities in whatsapp-web.js dependencies (puppeteer).
# Will be re-enabled when upstream fixes are available.
# To use: npm install whatsapp-web.js (at your own risk)
# =============================================================================

# Configuration WhatsApp Handler
# Utilise whatsapp-web.js (connexion via WhatsApp Web)

whatsapp:
  enabled: false  # Disabled by default - see deprecation notice above

  # Répertoire de session (pour persistance de l'auth)
  # Après le premier scan du QR code, la session est sauvegardée
  session_dir: "./data/whatsapp-session"

  # Mode headless pour Puppeteer (true = pas de fenêtre visible)
  headless: true

  # Arguments Puppeteer personnalisés (optionnel)
  # puppeteer_args:
  #   - "--no-sandbox"
  #   - "--disable-setuid-sandbox"

# IMPORTANT - Premier lancement:
# 1. Lancez PipeliNostr avec un workflow utilisant 'whatsapp'
# 2. Un QR code s'affichera dans la console
# 3. Scannez-le avec WhatsApp sur votre téléphone
# 4. La session sera sauvegardée pour les prochains lancements
