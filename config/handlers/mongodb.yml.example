# Configuration MongoDB Handler
mongodb:
  enabled: true

  # Connection string MongoDB
  # Format: mongodb://user:password@host:port/database
  # Ou: mongodb+srv://user:password@cluster.mongodb.net/
  connection_string: ${MONGODB_URI}

  # Base de données
  database: "pipelinostr"

  # Collection par défaut
  default_collection: "nostr_events"

# Exemple d'utilisation dans un workflow:
