# actions:
#   - type: mongodb
#     params:
#       operation: insert
#       collection: "events"
#
#   - type: mongodb
#     params:
#       operation: upsert
#       collection: "events"
#       upsert_key: "event_id"
#
#   - type: mongodb
#     params:
#       operation: update
#       filter:
#         pubkey: "{pubkey}"
#       update_fields:
#         last_seen: "{timestamp}"
#         message_count: { "$inc": 1 }
