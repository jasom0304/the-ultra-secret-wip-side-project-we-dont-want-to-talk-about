# PipeliNostr - Configuration des secrets
# Copiez ce fichier vers .env et remplissez les valeurs

# Nostr
NOSTR_PRIVATE_KEY=nsec1...

# API (optionnel)
API_KEY_1=sk_live_xxxxx
API_KEY_2=sk_live_yyyyy
JWT_SECRET=your-jwt-secret-here

# Email Handler
SMTP_PASSWORD=xxxxx

# Telegram Handler
TELEGRAM_BOT_TOKEN=123456:ABC-xxx

# Slack Handler
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXXXXXX
SLACK_BOT_TOKEN=xoxb-xxxx-xxxx-xxxx

# Zulip Handler
ZULIP_API_KEY=xxxxx

# WhatsApp Handler
# Note: WhatsApp utilise l'auth par QR code, pas de secret requis
# La session est persistée dans data/whatsapp-session/

# Signal Handler
# Numéro enregistré avec signal-cli (register + verify)
SIGNAL_PHONE_NUMBER=+33612345678

# Discord Handler
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy
DISCORD_BOT_TOKEN=xxx.yyy.zzz

# Twitter/X Handler
TWITTER_API_KEY=xxxxx
TWITTER_API_SECRET=xxxxx
TWITTER_ACCESS_TOKEN=xxxxx
TWITTER_ACCESS_TOKEN_SECRET=xxxxx

# Matrix Handler
MATRIX_ACCESS_TOKEN=syt_xxxxx

# Mastodon Handler
MASTODON_ACCESS_TOKEN=xxxxx

# FTP Handler
FTP_PASSWORD=xxxxx

# SFTP Handler
SFTP_PASSWORD=xxxxx
# SFTP_KEY_PASSPHRASE=xxxxx

# MongoDB Handler
MONGODB_URI=mongodb://localhost:27017/pipelinostr

# MySQL Handler
MYSQL_PASSWORD=xxxxx

# PostgreSQL Handler
POSTGRES_PASSWORD=xxxxx

# Redis Handler
# REDIS_PASSWORD=xxxxx

# S3 Handler (AWS, MinIO, Backblaze, Wasabi, etc.)
S3_ACCESS_KEY_ID=xxxxx
S3_SECRET_ACCESS_KEY=xxxxx

# Bluesky Handler
BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Lemmy Handler
LEMMY_PASSWORD=xxxxx

# GitHub Handler
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitLab Handler
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# MQTT Handler
# MQTT_PASSWORD=xxxxx

# ========================================
# Inbound Handlers
# ========================================

# Webhook Server
# WEBHOOK_GITHUB_SECRET=xxxxx
# WEBHOOK_GITLAB_SECRET=xxxxx

# API Poller (for authenticated APIs)
# API_TOKEN=xxxxx

# Traccar SMS Gateway
# Get token from Traccar SMS Gateway Android app
TRACCAR_SMS_TOKEN=xxxxx

# Bitcoin Wallet Handler (watch-only via xpub)
BITCOIN_XPUB=xpub6...
