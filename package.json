{
  "name": "pipelinostr",
  "version": "0.1.0",
  "description": "Nostr Event Router - Le n8n de Nostr",
  "main": "dist/index.js",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "build:clean": "npm run clean && npm run build",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "start": "node dist/index.js",
    "start:dev": "tsx watch src/index.ts",
    "dev": "npm run start:dev",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "keywords": [
    "nostr",
    "router",
    "event",
    "bridge",
    "automation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@atproto/api": "^0.13.19",
    "@aws-sdk/client-s3": "^3.700.0",
    "ajv": "^8.17.1",
    "basic-ftp": "^5.0.5",
    "bip32": "^5.0.0",
    "bitcoinjs-lib": "^7.0.0",
    "dotenv": "^16.4.7",
    "handlebars": "^4.7.8",
    "light-bolt11-decoder": "^3.2.0",
    "mongodb": "^6.12.0",
    "mysql2": "^3.11.5",
    "nodemailer": "^7.0.11",
    "nostr-tools": "^2.10.4",
    "pg": "^8.13.1",
    "pigpio-client": "^1.5.2",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "redis": "^4.7.0",
    "sql.js": "^1.11.0",
    "ssh2-sftp-client": "^11.0.0",
    "tiny-secp256k1": "^2.2.4",
    "ws": "^8.18.0",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.11.10",
    "@types/qrcode": "^1.5.6",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/sql.js": "^1.4.9",
    "@types/ssh2-sftp-client": "^9.0.4",
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.16.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
