# ClaudeDM Insufficient Balance Response
#
# Triggered when user doesn't have enough SATs.
# Called by on_fail hook from claudeDM-balance-gate.
#
# Context inherited from parent:
# - trigger.*: original DM event
# - parent.variables.min_balance_sats: required minimum

id: claudeDM-insufficient-balance
name: ClaudeDM - Insufficient Balance
enabled: false

trigger:
  type: hook
  source_workflow: claudeDM-balance-gate

actions:
  # Get current balance (may be 0 or not exist)
  - id: get_balance
    type: workflow_db
    config:
      action: get
      workflow_id: zap-balance-tracker
      namespace: balances
      key: "balance:{{ trigger.from }}"

  - id: reply
    type: nostr_dm
    config:
      to: "{{ trigger.from }}"
      content: |
        Solde insuffisant pour utiliser ClaudeDM.

        Votre solde: {{ default actions.get_balance.response.value 0 }} SATs
        Minimum requis: {{ parent.variables.min_balance_sats }} SATs

        Pour recharger votre solde, envoyez des zaps vers:
        npub1... (configurez votre npub cible ici)

        1 SAT zappe = 1 SAT de credit
