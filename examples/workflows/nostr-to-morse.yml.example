# Morse Code Buzzer - Play DM content as Morse code
#
# Converts text from Nostr DM to Morse code and plays it on a buzzer
# Also generates audio file and sends it to Telegram
#
# Command format:
#   morse: <text>
#   morse:slow: <text>    (slower speed)
#   morse:fast: <text>    (faster speed)
#
# Examples:
#   morse: SOS
#   morse: Hello World
#   morse:slow: CQ CQ CQ
#
# Prerequisites:
#   - Raspberry Pi with pigpiod running
#   - Buzzer connected to GPIO 27:
#     - Passive buzzer: set tone_freq to desired frequency (default: 800Hz)
#     - Active buzzer: set tone_freq: 0
#   - Telegram bot configured (for audio sending)
#   - ffmpeg installed (for OGG conversion)
#   - See docs/GPIO-MORSE-BUZZER.md for circuit diagram
#
# Morse timing at default speed (100ms unit = ~12 WPM):
#   - Dot: 100ms
#   - Dash: 300ms
#   - Letter gap: 300ms
#   - Word gap: 700ms

id: nostr-to-morse
name: Morse Code Buzzer
description: Play Nostr DM content as Morse code on a buzzer and send to Telegram
enabled: true

trigger:
  type: nostr_event
  filters:
    kinds: [4, 1059]
    from_whitelist: true
    content_pattern: "^morse:(?:(?<speed>slow|fast):)?\\s*(?<text>.+)$"

actions:
  # ============================================
  # STANDARD SPEED (~12 WPM)
  # ============================================

  # Play on GPIO buzzer
  - id: play_morse_normal
    type: gpio
    when: "!match.speed"
    config:
      pin: 27
      action: morse
      text: "{{ match.text }}"
      unit_ms: 100
      tone_freq: 800  # Hz for passive buzzer (use 0 for active buzzer)

  # Generate audio file
  - id: generate_audio_normal
    type: morse_audio
    when: "!match.speed"
    config:
      text: "{{ match.text }}"
      unit_ms: 100
      frequency: 700
      format: ogg

  # Send audio to Telegram (supports multiple files for long messages)
  - id: send_telegram_normal
    type: telegram
    when: "!match.speed && actions.generate_audio_normal.success"
    config:
      action: voice
      voice_files: "{{ actions.generate_audio_normal.response.files }}"

  # Confirmation DM
  - id: confirm_normal
    type: nostr_dm
    when: "!match.speed"
    config:
      to: "{{ trigger.from }}"
      content: |
        Morse (~12 WPM): "{{ match.text }}"

        {{ actions.play_morse_normal.response.morse }}

        ({{ actions.play_morse_normal.response.total_dots }} points, {{ actions.play_morse_normal.response.total_dashes }} traits)

  # ============================================
  # SLOW SPEED (~6 WPM)
  # ============================================

  # Play on GPIO buzzer
  - id: play_morse_slow
    type: gpio
    when: "match.speed === 'slow'"
    config:
      pin: 27
      action: morse
      text: "{{ match.text }}"
      unit_ms: 200
      tone_freq: 800  # Hz for passive buzzer (use 0 for active buzzer)

  # Generate audio file
  - id: generate_audio_slow
    type: morse_audio
    when: "match.speed === 'slow'"
    config:
      text: "{{ match.text }}"
      unit_ms: 200
      frequency: 700
      format: ogg

  # Send audio to Telegram (supports multiple files for long messages)
  - id: send_telegram_slow
    type: telegram
    when: "match.speed === 'slow' && actions.generate_audio_slow.success"
    config:
      action: voice
      voice_files: "{{ actions.generate_audio_slow.response.files }}"

  # Confirmation DM
  - id: confirm_slow
    type: nostr_dm
    when: "match.speed === 'slow'"
    config:
      to: "{{ trigger.from }}"
      content: |
        Morse lent (~6 WPM): "{{ match.text }}"

        {{ actions.play_morse_slow.response.morse }}

        ({{ actions.play_morse_slow.response.total_dots }} points, {{ actions.play_morse_slow.response.total_dashes }} traits)

  # ============================================
  # FAST SPEED (~20 WPM)
  # ============================================

  # Play on GPIO buzzer
  - id: play_morse_fast
    type: gpio
    when: "match.speed === 'fast'"
    config:
      pin: 27
      action: morse
      text: "{{ match.text }}"
      unit_ms: 60
      tone_freq: 800  # Hz for passive buzzer (use 0 for active buzzer)

  # Generate audio file
  - id: generate_audio_fast
    type: morse_audio
    when: "match.speed === 'fast'"
    config:
      text: "{{ match.text }}"
      unit_ms: 60
      frequency: 700
      format: ogg

  # Send audio to Telegram (supports multiple files for long messages)
  - id: send_telegram_fast
    type: telegram
    when: "match.speed === 'fast' && actions.generate_audio_fast.success"
    config:
      action: voice
      voice_files: "{{ actions.generate_audio_fast.response.files }}"

  # Confirmation DM
  - id: confirm_fast
    type: nostr_dm
    when: "match.speed === 'fast'"
    config:
      to: "{{ trigger.from }}"
      content: |
        Morse rapide (~20 WPM): "{{ match.text }}"

        {{ actions.play_morse_fast.response.morse }}

        ({{ actions.play_morse_fast.response.total_dots }} points, {{ actions.play_morse_fast.response.total_dashes }} traits)
