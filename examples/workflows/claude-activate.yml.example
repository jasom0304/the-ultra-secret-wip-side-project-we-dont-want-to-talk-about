# Workflow: Claude Workflow Activator
# Active un workflow généré par Claude
#
# Commandes:
#   /activate <workflow-id>  - Active et enregistre le workflow
#   /cancel [workflow-id]    - Annule un workflow en attente (ou tous si pas d'id)
#   /pending                 - Liste les workflows en attente
#
# Prérequis:
# - claude-workflow-generator.yml doit être actif
# - Un workflow doit avoir été généré avec /workflow

id: claude-activate
name: Claude Workflow Activator
description: Activate or cancel pending workflows generated by Claude
enabled: true

trigger:
  type: nostr_event
  filters:
    kinds: [4, 1059]
    from_whitelist: true
    content_pattern: "^/(?<command>activate|cancel|pending)(?:\\s+(?<workflowId>[\\w-]+))?$"

actions:
  # 1. Activer un workflow
  - id: activate
    type: workflow_activator
    when: "match.command === 'activate'"
    config:
      action: activate
      workflowId: "{{ match.workflowId }}"

  # 2. Annuler un workflow
  - id: cancel
    type: workflow_activator
    when: "match.command === 'cancel'"
    config:
      action: cancel
      workflowId: "{{ match.workflowId }}"

  # 3. Lister les workflows en attente
  - id: list
    type: workflow_activator
    when: "match.command === 'pending'"
    config:
      action: list

  # 4. Répondre succès activation
  - id: reply_activate_success
    type: nostr_dm
    when: "match.command === 'activate' && actions.activate.success"
    config:
      to: "{{ trigger.from }}"
      content: |
        Workflow active!

        {{ actions.activate.response.message }}

        Le workflow est maintenant operationnel.

  # 5. Répondre échec activation
  - id: reply_activate_error
    type: nostr_dm
    when: "match.command === 'activate' && !actions.activate.success"
    config:
      to: "{{ trigger.from }}"
      content: |
        Erreur: {{ actions.activate.error }}

        Utilisez /pending pour voir les workflows en attente.

  # 6. Répondre annulation
  - id: reply_cancel
    type: nostr_dm
    when: "match.command === 'cancel' && actions.cancel.success"
    config:
      to: "{{ trigger.from }}"
      content: "{{ actions.cancel.response.message }}"

  # 7. Répondre liste
  - id: reply_list
    type: nostr_dm
    when: "match.command === 'pending' && actions.list.success"
    config:
      to: "{{ trigger.from }}"
      content: "{{ actions.list.response.message }}"
