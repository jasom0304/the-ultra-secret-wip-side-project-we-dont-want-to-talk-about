# PipeliNostr Workflow Fetch Command
#
# Usage: /pipelinostr workflow fetch <event_id>
# Imports a workflow from a Nostr event (nevent1..., note1..., or hex ID)
# The workflow is saved as DISABLED by default for security.
#
# Example:
#   /pipelinostr workflow fetch nevent1qqsw...
#   /pipelinostr workflow fetch note1abc...

id: pipelinostr-workflow-fetch
name: PipeliNostr Workflow Fetch
enabled: true

trigger:
  type: nostr_event
  filters:
    kinds: [4]
    from_whitelist: true
    content_pattern: "^/pipelinostr\\s+workflow\\s+fetch\\s+(\\S+)"

actions:
  - id: fetch
    type: system
    action: workflow_fetch
    event_id: "{{ match.$1 }}"
    relay_urls:
      - "wss://relay.damus.io"
      - "wss://nos.lol"
      - "wss://relay.primal.net"
      - "wss://relay.nostr.band"

  - id: reply_success
    type: nostr_dm
    when: "{{ actions.fetch.success }}"
    to: "{{ trigger.from }}"
    content: "{{ actions.fetch.response.formatted }}"

  - id: reply_error
    type: nostr_dm
    when: "{{ not actions.fetch.success }}"
    to: "{{ trigger.from }}"
    content: "Error: {{ actions.fetch.error }}"
