# PipeliNostr Workflow Delete Command
#
# Usage: /pipelinostr workflow delete <workflow_id>
# Permanently deletes a workflow file.
# WARNING: This action cannot be undone!

id: pipelinostr-workflow-delete
name: PipeliNostr Workflow Delete
enabled: true

trigger:
  type: nostr_event
  filters:
    kinds: [4]
    from_whitelist: true
    content_pattern: "^/pipelinostr\\s+workflow\\s+delete\\s+(\\S+)"

actions:
  - id: delete
    type: system
    action: workflow_delete
    workflow_id: "{{ match.$1 }}"

  - id: reply_success
    type: nostr_dm
    when: "{{ actions.delete.success }}"
    to: "{{ trigger.from }}"
    content: "{{ actions.delete.response.formatted }}"

  - id: reply_error
    type: nostr_dm
    when: "{{ not actions.delete.success }}"
    to: "{{ trigger.from }}"
    content: "Error: {{ actions.delete.error }}"
