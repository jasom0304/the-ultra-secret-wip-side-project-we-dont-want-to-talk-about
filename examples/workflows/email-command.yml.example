# Send Email via Nostr DM
#
# Usage: Send a DM to PipeliNostr with:
#   Send email to recipient@example.com: Your message here
#
# Prerequisites:
# - Email handler enabled in config/handlers/email.yml
# - SMTP settings configured in .env
# - Sender npub in whitelist (config/config.yml)
#
# Available match.* variables:
# - match.to      : Email recipient (extracted from pattern)
# - match.message : Email body content

id: email-command
name: Send Email via DM
enabled: false

trigger:
  type: nostr_event
  filters:
    kinds: [4]
    from_whitelist: true
    content_pattern: "^[Ss]end email to (?<to>[^:]+):\\s*(?<message>.+)"

actions:
  - id: send_email
    type: email
    config:
      to: "{{ match.to | trim }}"
      subject: "Message from Nostr"
      body: "{{ match.message }}"
      html: |
          <html>
          <body style="font-family: Arial, sans-serif; padding: 20px;">
            <h2>Message from Nostr</h2>
            <p>{{ match.message }}</p>
            <hr style="margin-top: 30px;">
            <p style="color: #666; font-size: 12px;">
              Sent via PipeliNostr from {{ trigger.from }}
            </p>
          </body>
          </html>
