# ClaudeDM Error Response
#
# Called when Claude API request fails.
# Triggered by on_fail hook from claudeDM-process.
# User is NOT debited in case of error.

id: claudeDM-error-response
name: ClaudeDM - Error Response
enabled: false

trigger:
  type: hook
  source_workflow: claudeDM-process

actions:
  - id: reply
    type: nostr_dm
    config:
      to: "{{ trigger.from }}"
      content: |
        Erreur lors du traitement de votre requête ClaudeDM.

        Votre solde n'a pas été débité.

        Veuillez réessayer plus tard ou reformuler votre question.

        Si le problème persiste, contactez l'administrateur.
