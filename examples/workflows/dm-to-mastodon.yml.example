# Post to Mastodon via Nostr DM
#
# Send a DM with format "Mastodon: your message here" to post publicly on Mastodon.
#
# Prerequisites:
# 1. Create a Mastodon application:
#    - Go to Preferences > Development > New Application
#    - Required scope: write:statuses
#    - Copy "Your access token"
# 2. Configure config/handlers/mastodon.yml with your instance URL
# 3. Add MASTODON_ACCESS_TOKEN to .env
#
# Available variables:
# - trigger.from       : Sender npub
# - trigger.content    : Full message content
# - trigger.timestamp  : Unix timestamp
# - match.message      : Extracted message (after "Mastodon:")

id: dm-to-mastodon
name: Post to Mastodon via DM
enabled: true

trigger:
  type: nostr_event
  filters:
    kinds: [4]              # NIP-04 DMs
    from_whitelist: true    # Only from whitelisted npubs
    # Match "Mastodon: <message>" (case insensitive)
    content_pattern: "^[Mm]astodon:\\s*(?<message>.+)"

actions:
  - id: post_mastodon
    type: mastodon
    config:
      status: "(ceci est un message automatique posté depuis un DM Nostr via PipeliNostr)\n\n{{ match.message }}"
      visibility: public    # public, unlisted, private, direct
      # Optional settings:
      # language: "en"
      # sensitive: false
      # spoiler_text: "Content warning"

# Example usage:
# Send DM: "Mastodon: Hello world from Nostr! 🚀"
# Result: Posts "Hello world from Nostr! 🚀" publicly on your Mastodon account
