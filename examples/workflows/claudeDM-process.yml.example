# ClaudeDM Process - Claude API Call and Response
#
# Triggered by claudeDM-balance-gate on_complete hook.
# Calls Claude API, debits balance, sends response.
#
# Context inherited from parent (via pass_context: true):
# - trigger.*: original DM event (same as parent)
# - match.*: regex groups from parent (e.g., match.question)
# - parent.variables.*: parent workflow variables

id: claudeDM-process
name: ClaudeDM Process
enabled: false

trigger:
  type: hook
  source_workflow: claudeDM-balance-gate

actions:
  # Step 1: Get balance BEFORE processing
  - id: get_balance_before
    type: workflow_db
    config:
      action: get
      workflow_id: zap-balance-tracker
      namespace: balances
      key: "balance:{{ trigger.from }}"

  # Step 2: Call Claude API (with web search for up-to-date info)
  - id: claude_request
    type: claude
    config:
      action: chat
      message: "{{ match.question }}"
      max_tokens: 1000
      web_search: true
    on_fail:
      workflow: claudeDM-error-response
      pass_context: true

  # Step 3: Debit user's balance based on tokens used
  # Cost = ceil(tokens_used / 100), minimum 1 SAT (10 SATs per 1K tokens)
  - id: debit_balance
    type: workflow_db
    config:
      action: decrement
      workflow_id: zap-balance-tracker
      namespace: balances
      key: "balance:{{ trigger.from }}"
      amount: "{{ token_cost actions.claude_request.response.tokens_used }}"
      min_value: 0
      track_history: true

  # Step 4: Get balance AFTER debit
  - id: get_balance_after
    type: workflow_db
    config:
      action: get
      workflow_id: zap-balance-tracker
      namespace: balances
      key: "balance:{{ trigger.from }}"

  # Step 5: Reply to user with response and cost info
  - id: reply
    type: nostr_dm
    config:
      to: "{{ trigger.from }}"
      content: |
        {{ actions.claude_request.response.response }}

        ---
        Tokens: {{ actions.claude_request.response.tokens_used }} (in: {{ actions.claude_request.response.input_tokens }}, out: {{ actions.claude_request.response.output_tokens }})
        Cout: {{ token_cost actions.claude_request.response.tokens_used }} SATs
        Solde: {{ default actions.get_balance_before.response.value 0 }} → {{ default actions.get_balance_after.response.value 0 }} SATs
