# Workflow: Wallet Monitor Poll (Internal)
# Poll a monitored address for transaction updates
# Triggered by internal_poll events from the queue
#
# This workflow auto-reschedules itself until the target confirmations are reached

id: wallet-monitor-poll
name: Bitcoin Wallet - Monitor Poll
enabled: false

trigger:
  type: internal
  source: internal_poll

actions:
  # Poll the address for updates
  - id: poll
    type: wallet
    config:
      action: poll_monitor
      address: "{{ trigger.address }}"

  # Send notification if there's a state change
  # dm_format is automatically propagated from trigger context
  - id: notify
    type: nostr_dm
    when: "actions.poll.response.notification_message"
    config:
      to: "{{ actions.poll.response.target_pubkey }}"
      content: "{{ actions.poll.response.notification_message }}"

  # Schedule next poll if monitoring should continue
  - id: reschedule
    type: queue
    when: "actions.poll.response.should_continue"
    config:
      action: enqueue
      poll_type: address_monitor
      address: "{{ trigger.address }}"
      target_pubkey: "{{ actions.poll.response.target_pubkey }}"
      delay_ms: "{{ actions.poll.response.next_poll_delay_ms }}"
