# Workflow: DM to USB Dispenser
# Déclenche un distributeur via USB power cycling sur réception d'un DM "Zapoï !"
# Utilise uhubctl pour couper/rétablir l'alimentation d'un port USB
#
# Prérequis:
#   - sudo apt install uhubctl
#   - Hub USB avec PPPS (per-port power switching)
#   - Distributeur alimenté via USB
#
# Configuration sudoers (éviter mot de passe):
#   sudo visudo
#   pipelinostr ALL=(ALL) NOPASSWD: /usr/sbin/uhubctl

id: dm-to-usb-dispenser
name: DM to USB Dispenser
enabled: true
description: Déclenche le distributeur USB quand un DM "Zapoï !" est reçu

# Variables configurables
variables:
  hub: "1-1"           # Hub USB (voir 'sudo uhubctl')
  port: "all"          # Port du distributeur ("all" ou -1 pour tous les ports)
  cycle_delay: 2000    # Délai en ms entre off et on

trigger:
  type: dm
  filters:
    content_pattern: "(?i)^zapoi\\s*!?$"

actions:
  # Notification de réception
  - id: notify
    type: nostr_dm
    config:
      to: "{{ trigger.from }}"
      content: "Commande Zapoï reçue ! Distributeur en cours..."

  # Pulse du port USB (on -> delay -> off)
  - id: dispense
    type: usb_power
    config:
      hub: "{{ variables.hub }}"
      port: "{{ variables.port }}"
      action: pulse
      delay: "{{ variables.cycle_delay }}"

  # Confirmation
  - id: confirm
    type: nostr_dm
    config:
      to: "{{ trigger.from }}"
      content: "Distribution effectuée ! Zapoï !"
