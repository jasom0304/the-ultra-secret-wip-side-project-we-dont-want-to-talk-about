# Track events to MongoDB via Nostr DM
#
# Send a DM with format "mongo: your data here" to log to MongoDB.
# Optionally add a category: "mongo:category: data"
#
# Prerequisites:
# 1. MongoDB Atlas account with a cluster
# 2. Add MONGODB_CONNECTION_STRING to .env
# 3. Configure config/handlers/mongodb.yml
#
# Available variables:
# - trigger.from       : Sender npub
# - trigger.content    : Full message content
# - trigger.timestamp  : Unix timestamp
# - trigger.event      : Full Nostr event
# - match.category     : Optional category (if provided)
# - match.data         : The data to log

id: dm-to-mongodb
name: Track Event to MongoDB
enabled: true

trigger:
  type: nostr_event
  filters:
    kinds: [4]              # NIP-04 DMs
    from_whitelist: true    # Only from whitelisted npubs
    # Match "mongo: data" or "mongo:category: data"
    content_pattern: "^[Mm]ongo:(?:(?<category>\\w+):\\s*)?(?<data>.+)"

actions:
  - id: save_to_mongodb
    type: mongodb
    config:
      operation: insert
      collection: "event_tracking"
      document:
        event_id: "{{ trigger.event.id }}"
        source:
          platform: "nostr"
          pubkey: "{{ trigger.pubkey }}"
          npub: "{{ trigger.from }}"
          relay: "{{ trigger.relayUrl }}"
        event_type: "dm_command"
        category: "{{ default match.category 'general' }}"
        payload:
          command: "mongo"
          data: "{{ match.data }}"
        raw_content: "{{ trigger.content }}"
        event_timestamp: "{{ trigger.timestamp }}"
        received_at: "{{ now }}"
        status: "processed"

# Example usage:
#
# Simple log:
#   DM: "mongo: User clicked button X"
#   → category: "general", data: "User clicked button X"
#
# With category:
#   DM: "mongo:error: API timeout on endpoint /users"
#   → category: "error", data: "API timeout on endpoint /users"
#
#   DM: "mongo:metric: response_time=250ms"
#   → category: "metric", data: "response_time=250ms"
